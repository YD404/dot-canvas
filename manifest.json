{
  "name": "DotCanvas - Pixel Art Editor",
  "short_name": "DotCanvas",
  "description": "Browser-based Pixel Art Canvas Editor with Layers and Animation",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0a0a0a",
  "theme_color": "#171717",
